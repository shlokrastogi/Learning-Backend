<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>URL Shortener</title>
  </head>

  <body>
    <h1>URL Shortener</h1>
    <% if (locals.shortURL) { %>
    <p>Short URL: <a href="<%= shortURL %>"><%= shortURL %></a></p>
    <% } %>
    <div>
      <form action="/url" method="POST">
        <label for="fullUrl">Enter URL to shorten:</label>
        <input
          type="text"
          name="url"
          placeholder="https://example.com"
          required
        />
        <button type="submit">Generate</button>
      </form>
    </div>
    <div>
        <% if(locals.urls) { %>
            <table>
                <thead>
                    <th>S.No</th>
                    <th>Short ID</th>
                    <th>Redirect URL</th>
                    <th>Clicks</th>
                </thead>
                <tbody>
                    <% urls.forEach((url) => { %>
                        <tr>
                            <td><%= url._id %></td>
                            <td><%= url.shortId %></td>
                            <td><%= url.redirectURL %></td>
                            <td><%= url.visitHistory.length %></td>
                        </tr>
                    <% }) %>
                </tbody>

        <% } %>
    </div>
  </body>
</html>
